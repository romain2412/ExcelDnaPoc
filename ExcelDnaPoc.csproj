<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Platforms>x64</Platforms>
    <Platform>x64</Platform>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>true</UseWindowsForms>
    <UseWPF>true</UseWPF>

    <!-- Excel est en 64 bits sur cette machine : on ne g�n�re que le .xll 64 bits -->
    <ExcelAddInExplicitExports>true</ExcelAddInExplicitExports>
    <RunExcelDnaPack>true</RunExcelDnaPack>

    <!-- Expose les classes [ComVisible]+[ProgId] (ex. ChuckCom) comme serveur COM :
         ajoute ComServer="true" a l'ExternalLibrary du .dna genere. Couple a
         ComServer.DllRegisterServer() dans AutoOpen -> CreateObject() marche en VBA. -->
    <ExcelAddInComServer>true</ExcelAddInComServer>

    <!-- Genere/maj automatiquement Properties\launchSettings.json (profil "Excel")
         a chaque build : F5 dans Visual Studio lance EXCEL.EXE avec le .xll charge.
         ExcelDna detecte le bon chemin d'Excel et la bonne version (32/64 bits). -->
    <RunExcelDnaSetDebuggerOptions>true</RunExcelDnaSetDebuggerOptions>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ExcelDna.AddIn" Version="1.9.0" />
    <!-- IntelliSense en ligne (liste deroulante + infobulle d'arguments) pour les UDF :
         reutilise les metadonnees [ExcelFunction]/[ExcelArgument] deja declarees. -->
    <PackageReference Include="ExcelDna.IntelliSense" Version="1.9.0" />
  </ItemGroup>

  <!-- Config de demarrage + classeur de test copies a cote du .xll dans la sortie,
       pour que le demarrage (StartupLoader, chemins relatifs) fonctionne aussi en F5
       sous Visual Studio (qui charge le .xll non packe du dossier de sortie). -->
  <ItemGroup>
    <None Update="startup.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="TestAddin.xlsx">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- ChuckMacro.xlam est un ARTEFACT DERIVE (non versionne) regenere depuis
       ChuckMacro.bas a CHAQUE build, puis copie a cote du .xll (sortie F5/non packe).
       Necessite Excel + AccessVBOM ; ContinueOnError -> un build sans Excel (CI) ne
       casse pas. Launch-AddIn.ps1 lance le meme script pour le .xll packe (publish\). -->
  <Target Name="GenerateChuckXlam" AfterTargets="Build">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\Generate-Xlam.ps1&quot;"
          ContinueOnError="true" />
    <Copy SourceFiles="$(MSBuildProjectDirectory)\ChuckMacro.xlam"
          DestinationFolder="$(OutDir)"
          Condition="Exists('$(MSBuildProjectDirectory)\ChuckMacro.xlam')" />
  </Target>

</Project>
