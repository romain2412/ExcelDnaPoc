<UserControl x:Class="ExcelDnaPoc.WpfPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="13" Background="White">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- En-tete avec degrade : prouve que c'est bien du WPF -->
    <Border Grid.Row="0" CornerRadius="6" Padding="12" Margin="0,0,0,12">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#FF2E7D32" Offset="0"/>
          <GradientStop Color="#FF66BB6A" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
      <StackPanel>
        <TextBlock Text="Volet WPF" Foreground="White" FontSize="18" FontWeight="Bold"/>
        <TextBlock Text="POC ExcelDna - heberge dans un Custom Task Pane"
                   Foreground="#E8F5E9" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <!-- Traitements PARALLELES : une ligne (barre + Annuler) par traitement en cours -->
    <TextBlock Grid.Row="1" Text="Traitements (paralleles) :" Margin="0,0,0,4" FontWeight="SemiBold"/>
    <ScrollViewer Grid.Row="2" MaxHeight="200" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
      <StackPanel x:Name="JobsPanel"/>
    </ScrollViewer>

    <!-- Saisie -->
    <TextBlock Grid.Row="3" Text="Texte a ecrire dans la cellule active :" Margin="0,0,0,4"/>
    <TextBox Grid.Row="4" x:Name="InputBox" Text="Bonjour depuis WPF !"
             Padding="6" Margin="0,0,0,12"/>

    <!-- Actions -->
    <StackPanel Grid.Row="5" Orientation="Vertical">
      <Button x:Name="BtnWrite" Content="Ecrire dans la cellule active"
              Padding="8" Margin="0,0,0,6" Click="BtnWrite_Click"/>
      <Button x:Name="BtnRead" Content="Lire la cellule active"
              Padding="8" Margin="0,0,0,6" Click="BtnRead_Click"/>
      <Button x:Name="BtnCount" Content="Compter les cellules non vides (selection)"
              Padding="8" Margin="0,0,0,6" Click="BtnCount_Click"/>
    </StackPanel>

    <!-- Journal -->
    <TextBlock Grid.Row="6" Text="Journal :" Margin="0,8,0,4" FontWeight="SemiBold"/>
    <TextBox Grid.Row="7" x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto" Background="#FFF7F7F7"
             BorderBrush="#FFDDDDDD" Padding="6"/>
  </Grid>
</UserControl>
