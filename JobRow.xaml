<UserControl x:Class="ExcelDnaPoc.JobRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
  <Border BorderBrush="#FFDDDDDD" BorderThickness="1" CornerRadius="4"
          Padding="8" Margin="0,0,0,6">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" x:Name="StatusText" TextWrapping="Wrap" Margin="0,0,0,4"/>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <ProgressBar Grid.Column="0" x:Name="Progress" Height="18" Minimum="0" Maximum="100"
                     VerticalAlignment="Center"/>
        <Button Grid.Column="1" x:Name="BtnCancel" Content="Annuler"
                Margin="6,0,0,0" Padding="8,1" Click="BtnCancel_Click"/>
      </Grid>
    </Grid>
  </Border>
</UserControl>
